APP_NAME=RivalPulse Competitor Intelligence
APP_ENV=development
APP_HOST=0.0.0.0
WEB_PORT=3410
API_PORT=8410
APP_SECRET_KEY=replace-me-with-a-long-random-secret

DATABASE_URL=postgresql+psycopg2://app:app@db:5432/rivalpulse_ci
AUTO_CREATE_SCHEMA=true

STORAGE_ROOT=/app/data/storage
REPORTS_ROOT=/app/data/reports
OUTBOX_ROOT=/app/data/outbox

CRAWL_USER_AGENT=RivalPulseAI-Competitor-Intel/1.0
CRAWL_TIMEOUT_SECONDS=25
CRAWL_POLL_INTERVAL_SECONDS=20
SCHEDULER_INTERVAL_SECONDS=60
SYNC_MANUAL_CRAWLS=true
AUTO_REPORT_ENABLED=true
REPORT_CADENCE_DAYS=14

# Email delivery — fill in to enable scheduled report emails
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=reports@rivalpulse.local
REPORT_EMAIL_RECIPIENTS=

AI_PROVIDER=auto
AI_FALLBACK_ENABLED=true
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_ASK_MODEL=gpt-4o
OPENAI_EVENT_MODEL=gpt-4o-mini
OPENAI_REPORT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=40

DEFAULT_TENANT_SLUG=rivalpulse
DEFAULT_ADMIN_EMAIL=admin@rivalpulse.local
DEFAULT_ADMIN_PASSWORD=replace-me-local-password

POSTGRES_DB=rivalpulse_ci
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=55432
